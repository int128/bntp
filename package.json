    "@storybook/react-vite": "10.4.6",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@tsconfig/vite-react": "7.0.2",
    "@types/chrome": "0.2.0",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.9",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "pnpm": "11.5.3",
    "storybook": "10.4.6",
